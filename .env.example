# Database Connection
# For Docker Compose: postgres://postgres:postgres@db:5432/allerac_one
# For Local Dev: postgres://postgres:postgres@localhost:5432/allerac_one
DATABASE_URL=postgres://postgres:postgres@localhost:5432/allerac_one

# API URL (Optional, defaults to relative path in client)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# LLM Providers
# Ollama (Local)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# API Keys (Can also be set in User Settings UI)
TAVILY_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# Expensive operation limits (per user unless noted otherwise)
RATE_LIMIT_CHAT_REQUESTS=30
RATE_LIMIT_CHAT_WINDOW_SECONDS=60
CONCURRENCY_LIMIT_CHAT=2
RATE_LIMIT_BENCHMARK_REQUESTS=5
RATE_LIMIT_BENCHMARK_WINDOW_SECONDS=600
CONCURRENCY_LIMIT_BENCHMARK=1
RATE_LIMIT_IMAGE_EDIT_REQUESTS=10
RATE_LIMIT_IMAGE_EDIT_WINDOW_SECONDS=600
CONCURRENCY_LIMIT_IMAGE_EDIT=1
# Model downloads are limited globally across administrators
RATE_LIMIT_MODEL_DOWNLOAD_REQUESTS=3
RATE_LIMIT_MODEL_DOWNLOAD_WINDOW_SECONDS=3600
CONCURRENCY_LIMIT_MODEL_DOWNLOAD=1

# Encryption key for sensitive data (tokens stored in database)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Telegram Bot Token Encryption Key (32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_TOKEN_ENCRYPTION_KEY=

# Azure Storage (for Instagram image uploads)
# Requires Managed Identity on Azure VMs (no keys needed) or Azure CLI login locally
# Get storage account name from Azure Portal → Storage Accounts
AZURE_STORAGE_ACCOUNT_NAME=alleracstorage
AZURE_STORAGE_CONTAINER_NAME=social-posts

# TikTok Login Kit and Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-domain.example/api/tiktok/callback
# Must match a public URL prefix verified in TikTok for Developers.
TIKTOK_MEDIA_URL_PREFIX=https://alleracstorage.blob.core.windows.net/social-posts/tiktok/

# Spotify Web API (Music domain — recommendations from the user's own listening history)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://your-domain.example/api/spotify/callback

# Deploy webhook (optional, used with COMPOSE_PROFILES=webhook)
DEPLOY_BRANCH=development
COMPOSE_DIR=
WEBHOOK_SECRET=
GITHUB_DEPLOY_TOKEN=
DEPLOY_VM_NAME=sandbox-home
TELEGRAM_DEPLOY_BOT_TOKEN=
TELEGRAM_DEPLOY_CHAT_ID=

# ============================================
# Background agent worker
# ============================================
# Agent runs execute in the dedicated agent-worker container (see docker-compose.yml).
# The compose file sets DISABLE_AGENT_RUNNER=true on the web app so the runner does
# not also start there. The worker container ignores both flags below.
#
# DISABLE_AGENT_RUNNER=true    disables only the in-app agent runner (set by compose)
# DISABLE_BACKGROUND_WORKERS=true  legacy superset: disables the in-app runner AND the
#   scheduler logger that feeds the /logs UI. If you previously set this in .env to
#   avoid double execution, remove it — otherwise scheduler activity stops appearing
#   in the app logs. Used by test:e2e:release.
#
# Worker tuning (defaults shown; read by the agent-worker container):
# AGENT_ORCHESTRATION=false        multi-worker orchestration mode
# AGENT_WORKER_POLL_MS=3000        pending-run poll interval
# AGENT_WORKER_MAX_CONCURRENT=5    max concurrent runs
# AGENT_WORKER_TIMEOUT_MS=600000   per-worker execution timeout (10 min)
# AGENT_WORKER_SHUTDOWN_TIMEOUT_MS=25000  drain window on SIGTERM before exit
