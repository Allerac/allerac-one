# ============================================
# Allerac One - Cloud Services Line
# ============================================
# Copy to .env and fill in your values:
#   cp .env.cloud.example .env
#
# Or use the cloud installer which sets this up interactively:
#   ./install-cloud.sh
#
# Variables marked REQUIRED will cause startup to fail if not set.
# ============================================

# --------------------------------------------
# REQUIRED: Security keys
# Generate: openssl rand -hex 32
# Never commit these values or share them.
# --------------------------------------------
ENCRYPTION_KEY=
TELEGRAM_TOKEN_ENCRYPTION_KEY=
EXECUTOR_SECRET=

# --------------------------------------------
# REQUIRED: Cloudflare Tunnel
# Get token from: Cloudflare Zero Trust → Networks → Tunnels
# --------------------------------------------
TUNNEL_TOKEN=

# --------------------------------------------
# REQUIRED: Monitoring
# --------------------------------------------
GRAFANA_PASSWORD=

# --------------------------------------------
# LLM Providers
#
# GITHUB_TOKEN: GitHub Models API is the primary LLM for cloud.
# Users can also set their own token in the app Settings UI.
#
# OLLAMA_MODELS: models to download when using --profile ollama.
# Ollama runs containerized on the server — no inference data leaves the machine.
# --------------------------------------------
GITHUB_TOKEN=
OLLAMA_MODELS=qwen3.5:4b
NOTIFIER_LLM_MODEL=qwen3.5:4b

# --------------------------------------------
# External APIs (optional)
# --------------------------------------------
TAVILY_API_KEY=

# --------------------------------------------
# Telegram Bot (optional)
# --------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_DEFAULT_USER=

# --------------------------------------------
# Self-update: set to the project directory path
# Used by the agent when triggering updates via executor
# --------------------------------------------
COMPOSE_DIR=/home/allerac/allerac-one
