meta {
  name: Create Note
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/notes
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{apiKey}}
}

body:json {
  {
    "content": "Bruno smoke test note.",
    "title": "Control API smoke test",
    "tags": ["api", "bruno"],
    "source": "api"
  }
}

script:post-response {
  const body = res.getBody();
  if (body?.data?.note?.id) {
    bru.setEnvVar("noteId", body.data.note.id);
  }
}
