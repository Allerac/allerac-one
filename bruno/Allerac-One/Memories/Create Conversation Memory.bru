meta {
  name: Create Conversation Memory
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/conversations/{{conversationId}}/memory
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{apiKey}}
}

body:json {
  {
    "importanceScore": 8,
    "emotion": 0
  }
}

script:post-response {
  const body = res.getBody();
  if (body?.data?.memory?.id) {
    bru.setEnvVar("memoryId", body.data.memory.id);
  }
}
