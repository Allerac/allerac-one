# ============================================
# Allerac One - Local Hardware Line
# ============================================
# Copy to .env and fill in your values:
#   cp .env.local.example .env
#
# Or use the installer which generates this automatically:
#   ./install.sh
#
# Required:  ENCRYPTION_KEY
# Optional:  everything else (local AI works without external APIs)
# ============================================

# --------------------------------------------
# REQUIRED: Security (auto-generated by installer)
# Generate manually: openssl rand -hex 32
# --------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# AES key for encrypting Telegram bot tokens (needed if using Telegram)
# Generate: openssl rand -hex 32
TELEGRAM_TOKEN_ENCRYPTION_KEY=

# Secret for executor API authentication
# Generate: openssl rand -hex 16
EXECUTOR_SECRET=

# --------------------------------------------
# Hardware tier: models to download with Ollama
#
# Allerac Lite  (N100, 16GB):  qwen2.5:3b
# Allerac Home  (i5/R5, 32GB): qwen2.5:3b
# Allerac Pro   (i7/R7, 64GB): qwen2.5:3b
# --------------------------------------------
OLLAMA_MODELS=qwen2.5:3b
# GPU acceleration (auto-detected by install.sh)
# true  → uses docker-compose.local.gpu.yml override (requires nvidia-container-toolkit)
# false → CPU only
ENABLE_GPU=false

# Max RAM for Ollama container. Adjust to your hardware:
#   8GB  machine: OLLAMA_MEM_LIMIT=4g
#   16GB machine: OLLAMA_MEM_LIMIT=10g
#   32GB machine: OLLAMA_MEM_LIMIT=24g
OLLAMA_MEM_LIMIT=10g

# CPU threads for Ollama inference (leave 1 core free for the OS)
# N100 (4 cores) → 3, i5 (8 cores) → 6, i7 (12+ cores) → 10
OLLAMA_NUM_THREAD=3

# Keep model loaded in RAM between requests (avoids costly reloads)
OLLAMA_KEEP_ALIVE=1h

# Ollama API endpoint
# - Containerized Ollama (default): http://ollama:11434
# - Ollama installed on host:       http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# --------------------------------------------
# Database (no changes needed for local use)
# --------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=allerac

# --------------------------------------------
# Application ports
# --------------------------------------------
APP_PORT=8080
OLLAMA_PORT=11434
GRAFANA_PORT=3001

# --------------------------------------------
# Executor: working directory accessible to the AI agent
# Change this to restrict file system access.
# Example: HOST_WORKSPACE=/home/user/projects
# --------------------------------------------
HOST_WORKSPACE=/home

# --------------------------------------------
# Monitoring (used with --profile monitoring)
# --------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --------------------------------------------
# External APIs (optional — local AI works without them)
# --------------------------------------------

# Web search via Tavily (https://tavily.com)
TAVILY_API_KEY=

# GitHub Models API — cloud LLM fallback
# Users can also set this in the app UI under Settings
GITHUB_TOKEN=

# --------------------------------------------
# Notifications (used with --profile notifications)
# Create a bot at https://t.me/BotFather
# --------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_DEFAULT_USER=

# Model used by the notifier service for generating notification content
NOTIFIER_LLM_MODEL=qwen2.5:3b
